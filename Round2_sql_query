with cte as(
SELECT 
	date,resource_id,
    sum((unixepoch(end_time) - unixepoch(start_time)) / 3600.0) 
    over(partition by date,resource_id order by end_time rows between unbounded preceding and current row) as duration_of_session,
    is_clock_in,is_clock_out,
  first_value(start_time) over(partition by date,resource_id ORDER by end_time rows between unbounded preceding and current row) as clock_in_time,
  last_value(end_time) over(partition by date,resource_id ORDER by end_time rows between unbounded preceding and unbounded following) as clock_out_time
FROM test_de
                           )
select date,resource_id,duration_of_session as total_hours,clock_in_time,clock_out_time from cte where is_clock_out=1
